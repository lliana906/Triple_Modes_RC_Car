// printf가 UART2로 나가도록 리다이렉트하는 함수
int __io_putchar(int ch) {
    HAL_UART_Transmit(&huart2, (uint8_t *)&ch, 1, HAL_MAX_DELAY);
    return ch;
}

// MCP2515 레지스터 읽기 함수
uint8_t MCP2515_ReadRegister(uint8_t address) {
    uint8_t read_instruction = 0x03;
    uint8_t result = 0;

    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET); // CS LOW
    HAL_SPI_Transmit(&hspi1, &read_instruction, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &address, 1, HAL_MAX_DELAY);
    HAL_SPI_Receive(&hspi1, &result, 1, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);   // CS HIGH

    return result;
}

// 8MHz 기준 500kbps 속도 설정 및 Normal 모드 전환 함수
void MCP2515_Init_CAN(void) {
    // 1. 8MHz 크리스탈 타이밍 설정 (CNF3, CNF2, CNF1 순서 연속 쓰기)
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET);
    uint8_t write_cmd = 0x02;
    uint8_t cnf_start_addr = 0x28; // CNF3 주소
    HAL_SPI_Transmit(&hspi1, &write_cmd, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &cnf_start_addr, 1, HAL_MAX_DELAY);

    uint8_t cnf_values[3] = {0x02, 0x90, 0x00}; // 500kbps 세팅값
    HAL_SPI_Transmit(&hspi1, cnf_values, 3, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);

    // 2. 일반 동작 모드(Normal Mode)로 전환
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET);
    uint8_t address = 0x0F;     // CANCTRL 주소
    uint8_t normal_mode = 0x00; // Normal 모드 비트
    HAL_SPI_Transmit(&hspi1, &write_cmd, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &address, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &normal_mode, 1, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);
}

// 데이터 전송 함수
void MCP2515_Send_TestData(void) {
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET);
    uint8_t write_instruction = 0x02;
    uint8_t start_address = 0x31; // TXB0SIDH 주소

    HAL_SPI_Transmit(&hspi1, &write_instruction, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &start_address, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, (uint8_t[]){0x12, 0x30, 0x00, 0x00}, 4, HAL_MAX_DELAY); // ID 0x123
    HAL_SPI_Transmit(&hspi1, (uint8_t[]){0x08}, 1, HAL_MAX_DELAY);                  // DLC 8

    uint8_t test_data[8] = {0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88};
    HAL_SPI_Transmit(&hspi1, test_data, 8, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);

    // RTS 명령
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET);
    uint8_t rts_instruction = 0x81;
    HAL_SPI_Transmit(&hspi1, &rts_instruction, 1, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);
}
