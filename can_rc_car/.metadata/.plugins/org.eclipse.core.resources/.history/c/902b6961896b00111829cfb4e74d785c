int main(void)
{
  HAL_Init();
  SystemClock_Config();

  /* Peripherals 초기화 */
  MX_GPIO_Init();
  MX_SPI1_Init();
  MX_USART2_UART_Init();

  /* USER CODE BEGIN 2 */
  printf("\r\n=== MCP2515 CAN 통신 테스트 시작 ===\r\n");

  // 초기 상태 확인 (0x0E 레지스터 읽기)
  mcp2515_status = MCP2515_ReadRegister(0x0E);
  printf("첫 칩 체크 (CANSTAT): %d (128이면 정상)\r\n", mcp2515_status);

  if(mcp2515_status == 128) {
      printf("-> 칩 인식 성공! 500kbps 설정 및 Normal 모드로 전환합니다.\r\n");
      MCP2515_Init_CAN();
  } else {
      printf("-> [경고] 칩이 올바른 응답을 주지 않습니다. SPI 배선이나 전원을 확인하세요.\r\n");
  }
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
      // 1. 데이터 송신 시도
      MCP2515_Send_TestData();

      // 2. 송신 버퍼 0번의 상태 레지스터(TXB0CTRL)와 모드 레지스터(CANSTAT) 확인
      tx_control_status = MCP2515_ReadRegister(0x30);
      mcp2515_status = MCP2515_ReadRegister(0x0E);

      printf("[주기 체크] 현재 모드(CANSTAT): %d | 송신버퍼상태(TXB0CTRL): 0x%02X\r\n", mcp2515_status, tx_control_status);

      if(tx_control_status & 0x08) {
          printf("   => [선로 막힘] 데이터 전송 요청이 걸려있으나 버스로 나가지 못하고 대기 중입니다! (GND/납땜/라파라인 점검 필요)\r\n");
      } else {
          printf("   => [송신 완료] 데이터가 성공적으로 버스로 방출되었습니다!\r\n");
      }

      printf("------------------------------------------------------------------\r\n");
      HAL_Delay(1000); // 1초 대기
    /* USER CODE END WHILE */
    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

