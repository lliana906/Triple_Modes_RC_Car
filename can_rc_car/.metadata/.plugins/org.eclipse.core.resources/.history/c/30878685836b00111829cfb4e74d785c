// 1. MCP2515 레지스터에서 1바이트 읽기
uint8_t MCP2515_ReadRegister(uint8_t address) {
    uint8_t read_instruction = 0x03;
    uint8_t result = 0;

    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET); // CS LOW
    HAL_SPI_Transmit(&hspi1, &read_instruction, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &address, 1, HAL_MAX_DELAY);
    HAL_SPI_Receive(&hspi1, &result, 1, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);   // CS HIGH

    return result;
}

// 2. MCP2515 레지스터에 1바이트 쓰기 (범용 함수 추가)
void MCP2515_WriteRegister(uint8_t address, uint8_t value) {
    uint8_t write_instruction = 0x02;

    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET); // CS LOW
    HAL_SPI_Transmit(&hspi1, &write_instruction, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &address, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &value, 1, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);   // CS HIGH
}

// 3. Normal Mode로 전환
void MCP2515_SetNormalMode(void) {
    MCP2515_WriteRegister(0x0F, 0x00); // CANCTRL = Normal Mode
}

// 4. 표준 ID 0x123으로 테스트 데이터 송신 (기존 테스트용, 유지)
void MCP2515_Send_TestData(void) {
    uint8_t write_instruction = 0x02;
    uint8_t start_address = 0x31; // TXB0SIDH

    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET);
    HAL_SPI_Transmit(&hspi1, &write_instruction, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, &start_address, 1, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, (uint8_t[]){0x12, 0x30, 0x00, 0x00}, 4, HAL_MAX_DELAY);
    HAL_SPI_Transmit(&hspi1, (uint8_t[]){0x08}, 1, HAL_MAX_DELAY);

    uint8_t test_data[8] = {0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77, 0x88};
    HAL_SPI_Transmit(&hspi1, test_data, 8, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);

    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET);
    uint8_t rts_instruction = 0x81; // RTS TXB0
    HAL_SPI_Transmit(&hspi1, &rts_instruction, 1, HAL_MAX_DELAY);
    HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);
}

// 5. 라즈베리파이로부터 CAN 메시지(ID=0x100) 수신 확인 및 읽기
//    RXB0에 메시지가 들어왔는지 CANINTF(0x2C) 레지스터의 RX0IF 비트로 확인
uint8_t MCP2515_CheckAndReadRX0(uint8_t *rx_data, uint8_t *rx_dlc) {
    uint8_t canintf = MCP2515_ReadRegister(0x2C); // CANINTF 레지스터

    if (canintf & 0x01) { // RX0IF 비트(bit0) 가 1이면 수신 데이터 있음
        // RXB0SIDH(0x61)부터 읽기 시작
        uint8_t read_instruction = 0x03;
        uint8_t start_addr = 0x61;

        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET); // CS LOW
        HAL_SPI_Transmit(&hspi1, &read_instruction, 1, HAL_MAX_DELAY);
        HAL_SPI_Transmit(&hspi1, &start_addr, 1, HAL_MAX_DELAY);

        uint8_t header[5]; // SIDH, SIDL, EID8, EID0, DLC
        HAL_SPI_Receive(&hspi1, header, 5, HAL_MAX_DELAY);

        uint8_t dlc = header[4] & 0x0F; // DLC는 하위 4비트
        if (dlc > 8) dlc = 8;

        HAL_SPI_Receive(&hspi1, rx_data, dlc, HAL_MAX_DELAY);
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET); // CS HIGH

        *rx_dlc = dlc;

        // RX0IF 플래그 클리어 (Bit Modify 명령 0x05 사용)
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_RESET);
        uint8_t bitmod_cmd[4] = {0x05, 0x2C, 0x01, 0x00}; // CANINTF의 RX0IF 클리어
        HAL_SPI_Transmit(&hspi1, bitmod_cmd, 4, HAL_MAX_DELAY);
        HAL_GPIO_WritePin(GPIOC, GPIO_PIN_8, GPIO_PIN_SET);

        return 1; // 수신 성공
    }
    return 0; // 수신 데이터 없음
}

// 6. UART로 디버그 메시지 출력
void Debug_Print(char *msg) {
    HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), 100);
}

